<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>이주영 — HR Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #F7F5F0;
  --surface: #FFFFFF;
  --ink: #1A1916;
  --ink2: #6B6860;
  --ink3: #A8A49E;
  --accent: #2A5C45;
  --accent2: #4E8C6F;
  --accent-bg: #EBF2EE;
  --gold: #B8934A;
  --gold-bg: #FBF4E8;
  --border: #E8E4DC;
  --serif: 'DM Serif Display', Georgia, serif;
  --sans: 'DM Sans', system-ui, sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--ink);
  line-height: 1.6;
  font-size: 15px;
  -webkit-font-smoothing: antialiased;
}

/* ── HERO ── */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-rows: auto 1fr auto;
  padding: 0;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute; inset: 0;
  background: #1A1916;
  z-index: 0;
}
.hero-bg::after {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 70% 40%, #2A5C4520 0%, transparent 60%),
              radial-gradient(ellipse 40% 80% at 10% 80%, #B8934A15 0%, transparent 50%);
}

.hero-nav {
  position: relative; z-index: 2;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28px 48px;
}

.logo {
  font-family: var(--serif);
  font-size: 17px;
  color: #fff;
  letter-spacing: 0.02em;
}

.hero-nav-links {
  display: flex; gap: 32px; list-style: none;
}
.hero-nav-links a {
  color: #ffffff80;
  text-decoration: none;
  font-size: 13px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  transition: color 0.2s;
}
.hero-nav-links a:hover { color: #fff; }

.hero-main {
  position: relative; z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 48px;
  max-width: 900px;
}

.hero-eyebrow {
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent2);
  margin-bottom: 20px;
  display: flex; align-items: center; gap: 10px;
}
.hero-eyebrow::before {
  content: '';
  display: block;
  width: 32px; height: 1px;
  background: var(--accent2);
}

.hero-h1 {
  font-family: var(--serif);
  font-size: clamp(52px, 7vw, 88px);
  color: #fff;
  line-height: 1.0;
  margin-bottom: 28px;
  letter-spacing: -0.02em;
}
.hero-h1 em {
  font-style: italic;
  color: var(--accent2);
}

.hero-sub {
  font-size: 16px;
  color: #ffffff70;
  max-width: 480px;
  line-height: 1.7;
  margin-bottom: 40px;
  font-weight: 300;
}

.hero-tags {
  display: flex; flex-wrap: wrap; gap: 8px;
  margin-bottom: 48px;
}
.hero-tag {
  font-size: 11px;
  padding: 5px 14px;
  border-radius: 20px;
  letter-spacing: 0.04em;
  border: 1px solid;
}
.ht-g { border-color: #ffffff25; color: #ffffff70; }
.ht-a { border-color: var(--accent2); color: var(--accent2); }

.hero-cta {
  display: flex; gap: 14px; align-items: center;
}
.btn-primary {
  background: var(--accent);
  color: #fff;
  padding: 13px 28px;
  border-radius: 6px;
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.04em;
  transition: background 0.2s, transform 0.15s;
}
.btn-primary:hover { background: var(--accent2); transform: translateY(-1px); }
.btn-ghost {
  color: #ffffff60;
  text-decoration: none;
  font-size: 13px;
  letter-spacing: 0.04em;
  display: flex; align-items: center; gap: 6px;
  transition: color 0.2s;
}
.btn-ghost:hover { color: #fff; }
.btn-ghost::after { content: '↗'; font-size: 14px; }

.hero-footer {
  position: relative; z-index: 2;
  padding: 28px 48px;
  display: flex; justify-content: space-between; align-items: center;
  border-top: 1px solid #ffffff10;
}
.hero-contact {
  display: flex; gap: 24px;
}
.hero-contact a {
  font-size: 12px; color: #ffffff40;
  text-decoration: none; letter-spacing: 0.04em;
  transition: color 0.2s;
}
.hero-contact a:hover { color: #ffffff90; }
.hero-scroll {
  font-size: 11px; color: #ffffff30;
  letter-spacing: 0.08em; text-transform: uppercase;
  display: flex; align-items: center; gap: 8px;
}
.scroll-line {
  width: 40px; height: 1px; background: #ffffff20;
}

/* ── LAYOUT ── */
.section {
  padding: 96px 48px;
  max-width: 1100px;
  margin: 0 auto;
}
.section-inner { max-width: 820px; }

.sec-label {
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink3);
  margin-bottom: 48px;
  display: flex; align-items: center; gap: 14px;
}
.sec-label::after {
  content: '';
  display: block;
  height: 1px; flex: 1;
  background: var(--border);
  max-width: 200px;
}

.sec-title {
  font-family: var(--serif);
  font-size: clamp(36px, 4vw, 52px);
  line-height: 1.1;
  margin-bottom: 16px;
  letter-spacing: -0.02em;
}
.sec-title em { font-style: italic; color: var(--accent); }

/* ── EXPERIENCE ── */
.exp-grid { display: flex; flex-direction: column; gap: 2px; margin-top: 56px; }

.exp-item {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  transition: border-color 0.2s;
}
.exp-item:hover { border-color: var(--accent2); }

.exp-header {
  padding: 28px 32px;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16px;
  align-items: flex-start;
  cursor: pointer;
  user-select: none;
}
.exp-company {
  font-family: var(--serif);
  font-size: 22px;
  margin-bottom: 4px;
}
.exp-role {
  font-size: 13px;
  color: var(--ink2);
  font-weight: 300;
}
.exp-right { text-align: right; }
.exp-period {
  font-size: 12px; color: var(--ink3);
  letter-spacing: 0.04em; margin-bottom: 8px;
}
.exp-tags { display: flex; flex-wrap: wrap; gap: 4px; justify-content: flex-end; }
.etag {
  font-size: 10px; padding: 2px 8px;
  border-radius: 3px;
  background: var(--accent-bg);
  color: var(--accent);
  letter-spacing: 0.04em;
}
.etag-gold { background: var(--gold-bg); color: var(--gold); }
.etag-gray { background: #F2F0EB; color: var(--ink2); }

.exp-body {
  max-height: 0; overflow: hidden;
  transition: max-height 0.35s ease, padding 0.3s;
  padding: 0 32px;
}
.exp-item.open .exp-body {
  max-height: 600px;
  padding: 0 32px 28px;
}
.exp-divider {
  height: 1px; background: var(--border);
  margin-bottom: 20px;
}
.exp-bullets { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.exp-bullets li {
  font-size: 14px; color: var(--ink2);
  padding-left: 18px; position: relative;
  line-height: 1.6; font-weight: 300;
}
.exp-bullets li::before {
  content: '—';
  position: absolute; left: 0;
  color: var(--accent2);
}
.exp-bullets li strong { color: var(--ink); font-weight: 500; }

.exp-toggle {
  width: 28px; height: 28px;
  border-radius: 50%;
  border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; color: var(--ink3);
  transition: transform 0.3s, border-color 0.2s, color 0.2s;
  flex-shrink: 0; margin-top: 4px;
}
.exp-item.open .exp-toggle {
  transform: rotate(45deg);
  border-color: var(--accent2);
  color: var(--accent);
}

/* ── SKILLS ── */
.skills-bg {
  background: #1A1916;
  padding: 96px 48px;
}
.skills-inner {
  max-width: 1100px; margin: 0 auto;
}
.skills-sec-label {
  font-size: 11px; letter-spacing: 0.12em;
  text-transform: uppercase; color: #ffffff30;
  margin-bottom: 48px;
  display: flex; align-items: center; gap: 14px;
}
.skills-sec-label::after {
  content: ''; height: 1px; flex: 1;
  background: #ffffff15; max-width: 200px;
}
.skills-title {
  font-family: var(--serif);
  font-size: clamp(36px, 4vw, 52px);
  color: #fff; margin-bottom: 56px;
  line-height: 1.1; letter-spacing: -0.02em;
}
.skills-title em { font-style: italic; color: var(--accent2); }

.skills-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 2px;
}
.skill-card {
  background: #ffffff08;
  border: 1px solid #ffffff10;
  border-radius: 12px;
  padding: 24px;
  transition: background 0.2s, border-color 0.2s;
}
.skill-card:hover { background: #ffffff12; border-color: #ffffff20; }
.skill-cat {
  font-size: 10px; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--accent2);
  margin-bottom: 14px; font-weight: 500;
}
.skill-pills { display: flex; flex-wrap: wrap; gap: 6px; }
.skill-pill {
  font-size: 12px; padding: 4px 10px;
  border-radius: 4px;
  background: #ffffff08;
  color: #ffffff70;
  border: 1px solid #ffffff10;
}
.skill-pill.ai {
  background: #2A5C4520;
  color: var(--accent2);
  border-color: var(--accent2);
}

.ai-note {
  margin-top: 40px;
  background: #ffffff06;
  border: 1px solid #ffffff10;
  border-left: 3px solid var(--accent2);
  border-radius: 8px;
  padding: 20px 24px;
  font-size: 13px; color: #ffffff60;
  line-height: 1.7; font-weight: 300;
}
.ai-note span { color: var(--accent2); font-weight: 500; }

/* ── AWARDS ── */
.award-card {
  background: var(--gold-bg);
  border: 1px solid #D4A85530;
  border-radius: 16px;
  padding: 36px 40px;
  margin-bottom: 16px;
  position: relative; overflow: hidden;
}
.award-card::before {
  content: '';
  position: absolute; top: 0; left: 0;
  width: 4px; height: 100%;
  background: var(--gold);
}
.award-badge {
  font-size: 11px; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--gold);
  margin-bottom: 10px; font-weight: 500;
  display: flex; align-items: center; gap: 8px;
}
.award-badge::before { content: '★'; font-size: 12px; }
.award-title {
  font-family: var(--serif);
  font-size: 24px; margin-bottom: 10px;
  color: var(--ink);
}
.award-desc {
  font-size: 14px; color: var(--ink2);
  line-height: 1.7; font-weight: 300;
}

.thesis-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px 32px;
}
.thesis-label {
  font-size: 11px; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--ink3);
  margin-bottom: 8px;
}
.thesis-title {
  font-family: var(--serif);
  font-size: 20px; margin-bottom: 8px;
}
.thesis-desc { font-size: 14px; color: var(--ink2); font-weight: 300; }

/* ── ACTIVITIES ── */
.act-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
  margin-top: 48px;
}
.act-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px 28px;
  transition: border-color 0.2s, transform 0.15s;
}
.act-card:hover { border-color: var(--accent2); transform: translateY(-2px); }
.act-name {
  font-size: 15px; font-weight: 500;
  margin-bottom: 4px;
}
.act-period {
  font-size: 11px; color: var(--ink3);
  letter-spacing: 0.04em; margin-bottom: 10px;
}
.act-desc { font-size: 13px; color: var(--ink2); line-height: 1.6; font-weight: 300; }

/* ── GLOBAL ── */
.global-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2px; margin-top: 48px;
}
.global-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px;
  display: flex; gap: 16px; align-items: flex-start;
  transition: border-color 0.2s;
}
.global-card:hover { border-color: var(--accent2); }
.global-flag { font-size: 28px; }
.global-title { font-size: 15px; font-weight: 500; margin-bottom: 4px; }
.global-sub { font-size: 13px; color: var(--ink2); font-weight: 300; }

/* ── FOOTER ── */
.footer {
  background: #1A1916;
  padding: 60px 48px;
  text-align: center;
}
.footer-name {
  font-family: var(--serif);
  font-size: 36px; color: #fff;
  margin-bottom: 16px; letter-spacing: -0.02em;
}
.footer-links {
  display: flex; justify-content: center; gap: 24px;
  flex-wrap: wrap;
}
.footer-links a {
  font-size: 13px; color: #ffffff40;
  text-decoration: none; letter-spacing: 0.04em;
  transition: color 0.2s;
}
.footer-links a:hover { color: #ffffff90; }
.footer-copy {
  margin-top: 40px;
  font-size: 11px; color: #ffffff20;
  letter-spacing: 0.06em; text-transform: uppercase;
}

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}
.hero-eyebrow { animation: fadeUp 0.6s 0.1s both; }
.hero-h1      { animation: fadeUp 0.7s 0.2s both; }
.hero-sub     { animation: fadeUp 0.7s 0.35s both; }
.hero-tags    { animation: fadeUp 0.7s 0.45s both; }
.hero-cta     { animation: fadeUp 0.7s 0.55s both; }

/* ── RESPONSIVE ── */
@media (max-width: 700px) {
  .hero-nav, .section, .skills-bg, .footer { padding-left: 24px; padding-right: 24px; }
  .hero-main { padding: 0 24px; }
  .hero-footer { padding: 24px; flex-direction: column; gap: 12px; }
  .act-grid, .global-grid { grid-template-columns: 1fr; }
  .hero-nav-links { display: none; }
}
</style>
</head>
